# =============================================================================
# Hermes Agent — environment template
# =============================================================================
# Copy this file to your Hermes home as `.env` (the bootstrap script does this
# for you) and fill in the values below. This file is COMMITTED to the repo and
# must NEVER contain real secrets. The real `.env` lives in HERMES_HOME and is
# git-ignored.
#
# Hermes home (.env location):
#   Windows (Desktop installer): %LOCALAPPDATA%\hermes\.env
#   Linux/macOS (shell installer): ~/.hermes/.env
#   Override anywhere with the HERMES_HOME environment variable.
#   Find it exactly with:  hermes config env-path
#
# config.yaml references these via `api_key_env:` and `${VAR}` interpolation.
# Any `${VAR}` that is UNSET stays literal in config and will break the setting,
# so the tunables at the bottom ship with safe defaults — keep them set.
# =============================================================================

# ----- Inference provider API keys ------------------------------------------
# Only the providers you actually use need a key. Unused ones can stay blank;
# they simply won't be reachable in the fallback chain.

# OpenCode Zen (primary provider in config.yaml: opencode_zen)
OPENCODE_ZEN_API_KEY=

# NVIDIA NIM (config.yaml provider: nvidia_nim)
NVIDIA_API_KEY=


# Google AI Studio (config.yaml provider: google_ai_studio; also vision + auxiliary)
GOOGLE_API_KEY=

# ----- API server ------------------------------------------------------------
# Bearer key for the built-in OpenAI-compatible API server (`hermes serve` /
# `hermes dashboard`). Generate any strong random string.
API_SERVER_KEY=

# Optional: override the base URL used for OpenAI-compatible calls.
# Leave blank to use provider defaults.
OPENAI_BASE_URL=

# ----- Messaging platforms ---------------------------------------------------
# Telegram bot (config.yaml platforms.telegram.token = ${TELEGRAM_TOKEN}).
# Get a token from @BotFather. Leave blank to disable Telegram.
TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs allowed to talk to the bot (authorization).
TELEGRAM_ALLOWED_USERS=

# ----- Model defaults / tunables (interpolated in config.yaml) ---------------
# These MUST be set or the ${VAR} placeholders remain literal and break config.
# Safe defaults below match typical Hermes behavior — adjust as desired.
DEFAULT_TIMEOUT_SECONDS=600
DEFAULT_RETRY_MAX_ATTEMPTS=3
DEFAULT_RETRY_BACKOFF_SECONDS=2

# =============================================================================
# Add more keys here as you add providers/tools/MCP servers. Common examples:
#   OPENROUTER_API_KEY=        # provider: openrouter
#   ANTHROPIC_API_KEY=         # provider: anthropic
#   OPENAI_API_KEY=            # provider: openai-api
#   FIRECRAWL_API_KEY=         # web.backend: firecrawl (in this config.yaml)
#   XAI_API_KEY=               # x_search toolset / grok
#   DAYTONA_API_KEY=           # terminal.backend: daytona
#   MODAL_TOKEN_ID= / MODAL_TOKEN_SECRET=   # terminal.backend: modal
# =============================================================================
