# Environment variables required by this Hermes distribution.
# Copy to `.env` and fill in your own values before running.

# Primary provider (opencode-zen / big-pickle) — sign in and create/copy a Zen API key at https://opencode.ai/auth.
# (optional)
# OPENCODE_ZEN_API_KEY=

# Fallback + delegation provider (zenmux / claude-sonnet-5-free / claude-fable-5-free) — top up credits and create a Pay As You Go key at https://zenmux.ai/platform/pay-as-you-go; restrict the key to free models to use only free-tier quota.
# (optional)
# ZENMUX_API_KEY=

# Fallback provider (nvidia / glm-5.2) — generate a NVIDIA Build API key at https://build.nvidia.com/settings/api-keys.
# (optional)
# NVIDIA_API_KEY=

# Vision aux (gemini) — create a Google AI Studio Gemini API key at https://aistudio.google.com/app/apikey. GEMINI_API_KEY also accepted.
# (optional)
# GOOGLE_API_KEY=
